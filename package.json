{
  "name": "dungeon-crystal",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @dungeon-crystal/server db:generate",
    "db:migrate": "pnpm --filter @dungeon-crystal/server db:migrate",
    "db:studio": "pnpm --filter @dungeon-crystal/server db:studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
